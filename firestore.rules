rules_version = '2';

// ============================================================
// FIRESTORE SECURITY RULES — TEFA BAHAGIA POS
//
// Cara pakai:
//   1. Buka Firebase Console → Firestore Database → tab "Rules".
//   2. Salin-tempel isi berkas ini, lalu klik "Publish".
//
// Aplikasi ini memakai Firebase Anonymous Authentication
// (diaktifkan otomatis lewat js/firebase-config.js) sehingga
// rule di bawah mensyaratkan request datang dari sesi yang sudah
// "masuk" secara anonim lewat aplikasi — bukan dibuka bebas oleh
// siapa saja di internet tanpa melalui index.html ini.
//
// PENTING: Pastikan provider "Anonymous" sudah diaktifkan di
// Firebase Console → Authentication → Sign-in method, atau semua
// permintaan baca/tulis akan ditolak.
// ============================================================
service cloud.firestore {
  match /databases/{database}/documents {
    match /pos_tefa/{docId} {
      allow read, write: if request.auth != null;
    }
    // Tolak akses ke koleksi lain secara default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
